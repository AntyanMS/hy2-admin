# Сборка бинарника панели (PyInstaller), каталог panel/
/panel/.venv/
/panel/build/
/build/
/dist/
*.spec.bak
/dist/hy2-admin-panel
/dist/hy2-admin-panel-linux-amd64

__pycache__/
*.py[cod]
*$py.class

# Секреты и артефакты (не коммитить копии с прод-серверов)
.env
.env.*
*.log
**/backups/
*.pem
*.key
local-config*.json

# Локальные артефакты (не в репозиторий)
.backup/
.cursor/
tmp/
.local/hy2-admin/
